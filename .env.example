# Postgres local (Docker) — use estes valores com docker-compose
# Porta 5433 padrão para não conflitar com outros projetos na mesma máquina
DATABASE_URL=postgresql://radar:radar@localhost:5433/radar
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=radar
POSTGRES_USER=radar
POSTGRES_PASSWORD=radar

# Janela de coleta histórica
HISTORICO_INICIO=2006-01-01

# Logging
LOG_LEVEL=INFO
